# ============================================================
#  Proyecto Failover UAGRM - Variables de Entorno (EJEMPLO)
#  Copiar a .env y ajustar los valores según tu entorno
# ============================================================

# --- Base de Datos MySQL ---
MYSQL_DATABASE=zabbix
MYSQL_USER=zabbix
MYSQL_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
MYSQL_ROOT_PASSWORD=CAMBIA_ESTA_CONTRASEÑA

# --- Zabbix Server ---
ZBX_SERVER_HOST=zabbix-server
DB_SERVER_HOST=zabbix-db

# --- Zabbix Web ---
ZABBIX_WEB_PORT=8080

# --- Zabbix API (Credenciales de Admin) ---
ZABBIX_URL=http://zabbix-web:8080
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix

# --- Automation Engine ---
POLL_INTERVAL=10
FAILOVER_COOLDOWN=30
STATE_FILE=/app/data/engine_state.json
LOG_LEVEL=INFO

# --- Router GNS3 ---
ROUTER_IP=10.50.0.100
ROUTER_USER=admin
ROUTER_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
PRIMARY_GATEWAY=10.0.1.2
BACKUP_GATEWAY=10.0.2.2

# --- Red ---
MONITOR_SUBNET=10.50.0.0/16
